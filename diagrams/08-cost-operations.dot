digraph CostOperations {
    title [label="운영 단계 (월 1만 운행)"];

    인프라 [label="인프라 + SaaS / 약 295만/월"];
    인력 [label="운영 인력 3.5명 / 1,500~2,300만/월"];
    보험 [label="보험 분할 / 100~300만/월"];
    합계 [label="월 합계 / 2,000~3,300만/월"];
    pg [label="★ 별도 PG / GMV의 3.4%"];

    title -> 인프라;
    title -> 인력;
    title -> 보험;
    인프라 -> 합계;
    인력 -> 합계;
    보험 -> 합계;
    title -> pg;
}
