digraph CostRegulatory {
    title [label="법적·규제 절차"];

    pre [label="출시 전 / M0~M5 / 1,000~10,000만"];
    annual [label="매년 반복 12종"];
    crit [label="⚠ 위치정보 등록 6~12주 / 보험 4~6주 / M0 즉시 착수"];
    gray [label="⚠ 화물자동차법 회색지대 / 변호사 자문 필수"];

    title -> pre;
    title -> annual;
    pre -> crit;
    pre -> gray;
}
