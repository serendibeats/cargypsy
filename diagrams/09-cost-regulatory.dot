digraph CostRegulatory {
    title [label="법적·규제 절차 (출시 전 마일스톤 + 매년 반복)"];

    M0 [label="M0 / 법인 설립 (서울 144만) / 통신판매업 신고 (4만)"];
    M1 [label="M0+1개월 / 위치정보사업 등록 / 정기 접수창 진입 / ⚠ 격월 6회 사이클"];
    M15 [label="M0+1.5개월 / 보험 견적 청약 / 3개사 비교 / ⚠ 영업용 미가입 / 230만 과태료 + 형사"];
    M2 [label="M0+2개월 / 변호사 약관·정책 / 500~1,500만 / NICE 본인확인 계약 / 연 50~220만"];
    M3 [label="M0+3개월 / ✅ 위치정보 등록증 교부 / 앱 5종 스토어 심사 제출"];
    M4 [label="M0+4개월 / 백그라운드 위치 권한 / 첫 거절 대응 (+2~3주 버퍼)"];
    M5 [label="M5 / ✅ 공식 출시"];
    M6 [label="M6+ / PIA 자율 (선택) / 1,500~5,000만 / 투자 대비"];

    crit [label="⚠ 크리티컬 패스 2종 / (1) 위치정보사업 등록 6~12주 / (2) 보험 인수심사 4~6주 / 둘 다 M0 즉시 동시 착수"];

    annual [label="매년 반복 의무 12종"];
    a1 [label="통신판매업 면허세 (1월, 1.2~4만)"];
    a2 [label="위치정보사업 사업현황 보고"];
    a3 [label="보험 갱신 + 부가세 분기 신고"];
    a4 [label="법인세 (3월) / 원천세 (매월) / 4대보험 정산"];
    a5 [label="개인정보처리방침 갱신 / CPO 교육"];
    a6 [label="Apple Dev 갱신 ($99) / NICE 계약 갱신"];

    gray [label="⚠ 회색지대 / 화물자동차운수사업법 / 적용 여부 (탁송 vs 운전대행) / 별도 변호사 자문 필수"];

    M0 -> M1;
    M1 -> M15;
    M15 -> M2;
    M2 -> M3;
    M3 -> M4;
    M4 -> M5;
    M5 -> M6;

    M1 -> crit;
    M15 -> crit;

    annual -> a1;
    annual -> a2;
    annual -> a3;
    annual -> a4;
    annual -> a5;
    annual -> a6;

    M5 -> annual [label="출시 후"];
    M0 -> gray [label="출시 전 자문"];
}
