digraph CostOverview {
    title [label="카집사 비용 한눈에 / (M0=법인설립 / M5=출시 / M6+=운영)"];

    M0 [label="M0 / 법인 설립 / + 통신판매업 신고"];
    M5 [label="M5 / 공식 출시"];
    Mop [label="M6+ / 운영 단계"];

    dev [label="개발 단계 / (6~7개월, 1회성) / 약 4.4~5.7억 / 8~9 FTE + 부대비"];
    ops [label="운영 단계 / (매월 반복) / 약 2,000~3,300만/월 / + 결제 수수료 GMV의 3.4%"];
    reg [label="법적·규제 / (1회성 + 매년 반복) / 출시 전 약 1,000~10,000만 / + 매년 의무 12종"];

    crit [label="⚠ 크리티컬 패스 / 위치정보사업 등록 (6~12주) / 자동차취급업자 종합보험 (4~6주)"];

    M0 -> M5 [label="6~7개월"];
    M5 -> Mop [label="출시 후"];

    M0 -> dev [label="기간 전체"];
    M0 -> reg [label="M0 즉시 착수"];
    M5 -> ops;

    reg -> crit [label="놓치면 출시 연기"];
}
