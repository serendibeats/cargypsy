digraph Sequence {
    s1 [label="1. 차주 / 예약 + 결제"];
    s2 [label="2. 시스템 / 배차 push"];
    s3 [label="3. 입고기사 / 수락 + 픽업 / (외관 사진 10장)"];
    s4 [label="4. GPS 송신 / (5초 간격) / + 알림 5단계"];
    s5 [label="5. 공업사 / 입고 → 작업 시작"];
    s6 [label="6. 공업사 / 정비 진행 / → 완료 처리"];
    s7 [label="7. 출고기사 Call / (다른 기사 배정)"];
    s8 [label="8. 출고기사 / 반납 + 사진 10장"];
    s9 [label="9. 차계부 갱신 / + 다음 점검 알림"];

    s1 -> s2;
    s2 -> s3;
    s3 -> s4;
    s4 -> s5;
    s5 -> s6;
    s6 -> s7;
    s7 -> s8;
    s8 -> s9;
}
